{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": "./src",                    // <--- 1. Explicitly lock the source directory root
    "outDir": "./dist",                    // <--- 2. Direct your compiled output files clean layout
    "esModuleInterop": true,
    "allowImportingTsExtensions": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*"]                  // <--- 3. Ensure it only targets patterns inside src
}